{
	"log": {
		"access": "/dev/null",
		"loglevel": "error",
		"error": "/var/log/v2ray-error.log"
	},
	"routing": {
		"domainStrategy": "IPIfNonMatch",
		"rules": [
			{
				"type": "field",
				"domain": [
					"full:test.reverse.org"
				],
				"inboundTag": [
					"bridge"
				],
				"outboundTag": "ow-portal"
			},
			{
				"type": "field",
				"inboundTag": [
					"bridge"
				],
				"outboundTag": "ow"
			},
			{
				"type": "field",
				"network": "tcp,udp",
				"outboundTag": "vmess"
			}
		]
	},
	"reverse": {
		"bridges": [
			{
				"tag": "bridge",
				"domain": "test.reverse.org"
			}
		]
	},
	"inbounds": [
		{
			"listen": "0.0.0.0",
			"port": 1080,
			"protocol": "socks",
			"settings": {
				"auth": "noauth",
				"udp": true,
				"ip": "127.0.0.1"
			},
			"streamSettings": {
				"sockopt": {
					
				}
			},
			"tag": "socks_proxy",
			"sniffing": {
				"enabled": true,
				"destOverride": [
					"http",
					"tls"
				],
				"metadataOnly": false,
				"routeOnly": false
			}
		},
		{
			"port": 1081,
			"protocol": "dokodemo-door",
			"settings": {
				"followRedirect": true,
				"network": "tcp,udp",
				"timeout": 1800
			},
			"streamSettings": {
				"sockopt": {
					"tproxy": "tproxy"
				}
			},
			"tag": "transparent",
			"sniffing": {
				"enabled": true,
				"destOverride": [
					"http",
					"tls"
				],
				"metadataOnly": false,
				"routeOnly": false
			}
		},
		{
			"port": 1180,
			"protocol": "http",
			"settings": {
				"allowTransparent": false
			},
			"streamSettings": {
				"sockopt": {
					
				}
			},
			"tag": "http",
			"sniffing": {
				"enabled": true,
				"destOverride": [
					"http",
					"tls"
				],
				"metadataOnly": false,
				"routeOnly": false
			}
		}
	],
	"outbounds": [
		{
			"tag": "ow-portal",
			"protocol": "vmess",
			"settings": {
				"vnext": [
					{
						"address": "www.230720.xyz",
						"port": 443,
						"users": [
							{
								"id": "8aa39176-e716-4a47-aa53-99adbae32f63",
								"alterId": 0,
								"security": "auto",
								"level": 0
							}
						]
					}
				]
			},
			"streamSettings": {
				"network": "ws",
				"security": "tls",
				"tlsSettings": {
					"allowInsecure": false,
					"allowInsecureCiphers": false,
					"disableSystemRoot": false
				},
				"wsSettings": {
					"path": "/myow/"
				},
				"sockopt": {
					"mark": 255
				}
			}
		},
		{
			"tag": "ow",
			"protocol": "freedom",
			"settings": {
				
			},
			"streamSettings": {
				"sockopt": {
					"mark": 255
				}
			}
		},
		{
			"tag": "vmess",
			"protocol": "vmess",
			"settings": {
				"vnext": [
					{
						"address": "www.230720.xyz",
						"port": 443,
						"users": [
							{
								"id": "35d72c74-dca6-46f3-aa7e-52c901da3eaa",
								"alterId": 0,
								"security": "auto",
								"level": 0
							}
						]
					}
				]
			},
			"streamSettings": {
				"network": "ws",
				"security": "tls",
				"tlsSettings": {
					"allowInsecure": false,
					"allowInsecureCiphers": false,
					"disableSystemRoot": false
				},
				"wsSettings": {
					"path": "/mycar/"
				},
				"sockopt": {
					"mark": 255
				}
			}
		}
	]
}
